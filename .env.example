# SALT - Environment Configuration

# 1. Obtain your key from https://aistudio.google.com/
# 2. Copy this file to .env
# 3. DO NOT add a "VITE_GEMINI_API_URL" or similar. 
#    The SDK handles the endpoint automatically.
# 4. REJECT Copilot suggestions for "text-bison-001" or legacy PaLM endpoints.
#    Salt uses the latest Gemini 3 and 2.5 Flash models.

VITE_GEMINI_API_KEY=your_api_key_here