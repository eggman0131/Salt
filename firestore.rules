rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // For the "Salt" app prototype, we allow any authenticated user to read/write.
    // This prevents the issue where importing data (which wipes the DB) 
    // accidentally locks the user out by deleting their authorization record.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
  }
}
