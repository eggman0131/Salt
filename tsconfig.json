{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
      ],
    "baseUrl": ".",
    "skipLibCheck": true,
    "types": [
      "node",
      "tailwindcss"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
    "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/seed-data": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/seed-data": true
  },
  "typescript.tsserver.exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/seed-data"
  ]
}


