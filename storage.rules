rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is authorized
    function isAuthorized() {
      return request.auth != null;
    }

    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // User avatars: Allow any authenticated user to read/write (small family app)
    match /users/{userId}/{allPaths=**} {
      allow read: if true; // Public read for avatars
      allow write: if isAuthorized();
    }

    // Recipe images: Allow authenticated users to read/write
    match /recipes/{recipeId}/{allPaths=**} {
      allow read: if true; // Public read for recipe images
      allow write: if isAuthorized();
    }

    // Storage path used by simulated backend
    match /storage/{imageId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    // Canon embedding master snapshot shared across browsers.
    // TODO: change write to isAdmin() once admin custom claims are configured.
    match /canon/embeddings/{allPaths=**} {
      allow read: if isAuthorized();
      allow write: if isAuthorized();
    }

    // FDC (USDA Food Data Central) embeddings for item matching
    match /fdc/embeddings/{allPaths=**} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
  }
}
